# PostgreSQL — local sem Docker (host localhost)
DATABASE_URL="postgresql://piloto:piloto_dev@localhost:5432/piloto_apoio_v2?schema=public"

# PostgreSQL — dentro do Docker Compose (serviço db)
# DATABASE_URL="postgresql://piloto:piloto_dev@db:5432/piloto_apoio_v2?schema=public"

# HTTP API
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# CORS — origens Angular (cliente + admin)
CORS_ORIGINS=http://localhost:4200,http://localhost:4201

# Motor de escala — único caminho: CleanEngine (env legado ignorado)
# SCHEDULE_ENGINE_VERSION=CLEAN

WS_PATH_ADMIN=/ws/admin
WS_PATH_CLIENT=/ws/client
