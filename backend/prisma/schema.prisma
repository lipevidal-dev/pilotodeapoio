generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  OPERATOR
  PILOT
}

enum EmployeeType {
  PAO
  APAO
}

enum ScheduleMonthStatus {
  DRAFT
  GENERATED
  VALIDATING
  PUBLISHED
  ARCHIVED
}

enum RuleSeverity {
  CRITICAL
  WARNING
  INFO
}

enum RequestedDayOffStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AssignmentSource {
  MANUAL
  GENERATOR
  IMPORT
  REPAIR
}

enum EmployeeTypeAllowed {
  PAO
  APAO
  BOTH
}

enum ShiftCoverageType {
  REQUIRED
  PARALLEL
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(OPERATOR)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model Role {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique
  description  String?
  active       Boolean  @default(true)
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  employees Employee[]
}

model Employee {
  id              String       @id @default(uuid())
  name            String
  type            EmployeeType
  roleId          String?      @map("role_id")
  seniorityNumber Int          @default(1) @map("seniority_number")
  birthDate       DateTime?    @map("birth_date") @db.Date
  active          Boolean      @default(true)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  role                Role?                @relation(fields: [roleId], references: [id], onDelete: Restrict)
  scheduleAssignments ScheduleAssignment[]
  preAllocations      PreAllocation[]
  vacations           Vacation[]
  requestedDaysOff    RequestedDayOff[]
  flightAssignments   FlightAssignment[]
  ruleViolations      RuleViolation[]
  flightRestrictions  EmployeeFlightRestriction[]
  shiftRestrictions   EmployeeShiftRestriction[]
  preferredShifts     EmployeePreferredShift[]
  specificShiftRequests EmployeeSpecificShiftRequest[]
  isFcf               Boolean              @default(false) @map("is_fcf")
  fcfSchedule         Json                 @default("[]") @map("fcf_schedule")

  @@unique([type, seniorityNumber])
}

model EmployeeFlightRestriction {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  date       DateTime @db.Date
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@map("employee_flight_restrictions")
}

model EmployeeShiftRestriction {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  shiftId    String   @map("shift_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([employeeId, shiftId])
  @@index([employeeId])
  @@map("employee_shift_restrictions")
}

model EmployeePreferredShift {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  shiftId    String   @map("shift_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@unique([employeeId, shiftId])
  @@index([employeeId])
  @@map("employee_preferred_shifts")
}

model EmployeeSpecificShiftRequest {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  shiftId    String   @map("shift_id")
  year       Int?
  month      Int?
  dayOfMonth Int?     @map("day_of_month")
  weekday    Int?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift    Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_specific_shift_requests")
}

model Shift {
  id                  String              @id @default(uuid())
  code                String              @unique
  name                String
  startTime           String              @map("start_time")
  endTime             String              @map("end_time")
  durationHours       Float               @map("duration_hours")
  employeeTypeAllowed EmployeeTypeAllowed @map("employee_type_allowed")
  active              Boolean             @default(true)
  displayOrder        Int                 @default(0) @map("display_order")
  mandatoryCoverage   Boolean             @default(false) @map("mandatory_coverage")
  requiresT8PairNd    Boolean             @default(false) @map("requires_t8_pair_nd")
  coverageType        ShiftCoverageType   @default(REQUIRED) @map("coverage_type")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  employeeShiftRestrictions EmployeeShiftRestriction[]
  employeePreferredShifts EmployeePreferredShift[]
  employeeSpecificShiftRequests EmployeeSpecificShiftRequest[]
}

model ScheduleMonth {
  id        String              @id @default(uuid())
  year      Int
  month     Int
  status    ScheduleMonthStatus @default(DRAFT)
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  assignments    ScheduleAssignment[]
  preAllocations PreAllocation[]
  ruleViolations RuleViolation[]

  @@unique([year, month])
}

model ScheduleAssignment {
  id              String           @id @default(uuid())
  scheduleMonthId String           @map("schedule_month_id")
  employeeId      String           @map("employee_id")
  date            DateTime         @db.Date
  shiftCode       String           @map("shift_code")
  label           String?
  source          AssignmentSource @default(MANUAL)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  scheduleMonth ScheduleMonth @relation(fields: [scheduleMonthId], references: [id], onDelete: Cascade)
  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([scheduleMonthId, employeeId, date])
  @@index([scheduleMonthId, date])
  @@index([employeeId])
}

model RuleViolation {
  id              String       @id @default(uuid())
  scheduleMonthId String       @map("schedule_month_id")
  severity        RuleSeverity
  ruleCode        String       @map("rule_code")
  message         String
  date            String?
  employeeId      String?      @map("employee_id")
  createdAt       DateTime     @default(now()) @map("created_at")

  scheduleMonth ScheduleMonth @relation(fields: [scheduleMonthId], references: [id], onDelete: Cascade)
  employee      Employee?     @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([scheduleMonthId])
}

model PreAllocation {
  id              String   @id @default(uuid())
  scheduleMonthId String   @map("schedule_month_id")
  employeeId      String   @map("employee_id")
  date            DateTime @db.Date
  label           String
  notes           String?
  startTime       String?  @map("start_time")
  endTime         String?  @map("end_time")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  scheduleMonth ScheduleMonth @relation(fields: [scheduleMonthId], references: [id], onDelete: Cascade)
  employee      Employee      @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([scheduleMonthId, employeeId, date])
  @@index([scheduleMonthId])
}

model Vacation {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  startDate  DateTime @map("start_date") @db.Date
  endDate    DateTime @map("end_date") @db.Date
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model RequestedDayOff {
  id         String              @id @default(uuid())
  employeeId String              @map("employee_id")
  date       DateTime            @db.Date
  status     RequestedDayOffStatus @default(PENDING)
  notes      String?
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId, date])
}

model FlightAssignment {
  id          String           @id @default(uuid())
  employeeId  String           @map("employee_id")
  date        DateTime         @db.Date
  description String?
  source      AssignmentSource @default(MANUAL)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
}

model SystemConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}
